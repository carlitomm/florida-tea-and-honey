{% comment %}
  custom-header-pill.liquid
  ----------------------------------------------------------------------------
  Custom header styling for Florida Tea and Honey (KICK-inspired look).

  What it does (desktop only, >= 750px):
    - Wraps the centered nav menu + search in a rounded "pill" capsule.
    - Adds a thin vertical divider between the menu and the search icon.
    - Turns the right-hand action icons (account, cart) into circular buttons.

  Design notes:
    - Colors are NOT hard-coded. All fills/borders derive from the theme's
      own --color-foreground-rgb at low opacity, so they adapt to whatever
      color scheme is configured in the theme editor.
    - The search icon lands in the center column because search_position is set
      to "center" in sections/header-group.json (the header-row snippet honors
      a "center" value even though the admin dropdown only lists left/right).

  To revert: delete this file and remove its {% render %} call in
  sections/header.liquid, then set search_position back to "right".
{% endcomment %}
<style>
  /* Logo size is controlled by the theme's native "Logo height" setting
     (Theme settings → Logo → Logo height / Logo height on mobile). We no longer
     cap it here — that hard-coded cap overrode the setting and made the logo
     impossible to enlarge from the admin. The center pill keeps its own compact
     height via align-self: center (below), so a taller logo only grows the
     header, it does not stretch the pill. */

  @media screen and (min-width: 750px) {
    /* --- Center nav pill: wraps menu + search --- */
    .header__column--center {
      --pill-border: rgb(var(--color-foreground-rgb) / 0.28);
      --pill-bg: rgb(var(--color-foreground-rgb) / 0.12);
      display: flex;
      align-items: center;
      /* Keep the pill at its own compact height: don't stretch to match a
         taller logo. The logo can grow without the pill growing with it. */
      align-self: center;
      gap: var(--gap-lg, 1.25rem);
      padding-block: 0.55rem;
      padding-inline: 1.75rem;
      border: 1px solid var(--pill-border);
      border-radius: 999px;
      background: var(--pill-bg);
    }

    /* Thin vertical divider before the search icon, inside the pill */
    .header__column--center .search-action {
      margin-inline-start: 0.25rem;
      padding-inline-start: 1.25rem;
      border-inline-start: 1px solid var(--pill-border);
    }

    /* Separate the account + cart buttons (their flex container has no gap) */
    .header__column--right > *:has(> .header-actions__action) {
      gap: 0.65rem;
    }

    /* --- Right-side circular icon buttons (account + cart) --- */
    .header__column--right .header-actions__action:not(.localization-selector) {
      inline-size: 2.75rem;
      block-size: 2.75rem;
      border: 1px solid rgb(var(--color-foreground-rgb) / 0.18);
      border-radius: 50%;
      display: inline-grid;
      place-items: center;
      transition: background-color 0.15s ease, border-color 0.15s ease;
    }

    .header__column--right .header-actions__action:not(.localization-selector):hover {
      background: rgb(var(--color-foreground-rgb) / 0.08);
      border-color: rgb(var(--color-foreground-rgb) / 0.3);
    }
  }

  /* On mobile the menu collapses to a drawer; keep the native layout and let
     the theme's drawer search handle search instead of the centered icon. */
  @media screen and (max-width: 749px) {
    .header__column--center .search-action {
      display: none;
    }
  }

  /* --- Submenu (☰) button on the LEFT of the pill + dropdown panel ---
     Links come from a theme setting (Theme settings → Header submenu), managed
     in Online Store → Navigation. Hidden until JS moves it into the pill. */
  .pill-submenu {
    display: none;
    position: relative;
    align-items: center;
    padding-inline-end: 1.1rem;
    border-inline-end: 1px solid var(--pill-border, rgb(var(--color-foreground-rgb) / 0.28));
  }

  @media screen and (min-width: 750px) {
    .pill-submenu.is-ready {
      display: inline-flex;
    }
  }

  .pill-submenu__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--color-foreground);
  }

  .pill-submenu__bars {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
    width: 19px;
  }

  .pill-submenu__bars span {
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.18s ease, opacity 0.18s ease;
  }

  .pill-submenu__toggle[aria-expanded='true'] .pill-submenu__bars span:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
  }
  .pill-submenu__toggle[aria-expanded='true'] .pill-submenu__bars span:nth-child(2) {
    opacity: 0;
  }
  .pill-submenu__toggle[aria-expanded='true'] .pill-submenu__bars span:nth-child(3) {
    transform: translateY(-5px) rotate(-45deg);
  }

  .pill-submenu__panel {
    position: absolute;
    inset-block-start: calc(100% + 0.8rem);
    inset-inline-start: 0;
    z-index: 90;
    min-width: 220px;
    max-width: 90vw;
    padding: 1.25rem 1.5rem;
    border-radius: 14px;
    background: var(--color-background);
    color: var(--color-foreground);
    box-shadow: 0 16px 40px rgb(0 0 0 / 0.22);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
  }

  .pill-submenu__panel[hidden] {
    display: none;
  }

  .pill-submenu__cols {
    display: flex;
    gap: 2.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pill-submenu__col {
    min-width: 120px;
  }

  .pill-submenu__heading {
    display: block;
    font-weight: 600;
    color: var(--color-foreground);
    text-decoration: none;
    margin-block-end: 0.5rem;
    white-space: nowrap;
  }

  .pill-submenu__sublist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .pill-submenu__link {
    color: rgb(var(--color-foreground-rgb) / 0.8);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .pill-submenu__heading:hover,
  .pill-submenu__link:hover {
    color: var(--color-primary);
  }
</style>

{%- if settings.pill_submenu_menu != blank and settings.pill_submenu_menu.links.size > 0 -%}
  <div class="pill-submenu" id="PillSubmenu">
    <button
      type="button"
      class="pill-submenu__toggle"
      aria-haspopup="true"
      aria-expanded="false"
      aria-label="Open menu"
    >
      <span class="pill-submenu__bars" aria-hidden="true"><span></span><span></span><span></span></span>
    </button>

    <div class="pill-submenu__panel color-{{ settings.popover_color_scheme }}" hidden>
      <ul class="pill-submenu__cols" role="list">
        {%- for link in settings.pill_submenu_menu.links -%}
          <li class="pill-submenu__col">
            <a class="pill-submenu__heading" href="{{ link.url }}">{{ link.title }}</a>
            {%- if link.links.size > 0 -%}
              <ul class="pill-submenu__sublist" role="list">
                {%- for child in link.links -%}
                  <li><a class="pill-submenu__link" href="{{ child.url }}">{{ child.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>

  <script>
    (function () {
      function init() {
        var sm = document.getElementById('PillSubmenu');
        if (!sm) return;
        var pill = document.querySelector('.header__column--center');
        if (pill && sm.parentElement !== pill) {
          pill.insertBefore(sm, pill.firstChild);
        }
        sm.classList.add('is-ready');
        if (sm.dataset.bound) return;
        sm.dataset.bound = '1';
        var toggle = sm.querySelector('.pill-submenu__toggle');
        var panel = sm.querySelector('.pill-submenu__panel');
        if (!toggle || !panel) return;
        function close() { panel.hidden = true; toggle.setAttribute('aria-expanded', 'false'); }
        function open() { panel.hidden = false; toggle.setAttribute('aria-expanded', 'true'); }
        toggle.addEventListener('click', function (e) { e.stopPropagation(); panel.hidden ? open() : close(); });
        document.addEventListener('click', function (e) { if (!sm.contains(e.target)) close(); });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
      }
      if (document.readyState !== 'loading') init();
      else document.addEventListener('DOMContentLoaded', init);
    })();
  </script>
{%- endif -%}
