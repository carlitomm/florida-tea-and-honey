{% comment %}
  custom-announcement-marquee.liquid
  ----------------------------------------------------------------------------
  KICK-inspired scrolling announcement bar. Replaces the stock fade-between
  slideshow with a continuous horizontal marquee: the announcement message(s)
  repeated across a bold filled bar, separated by a glyph (leaf by default).

  Rendered from sections/header-announcements.liquid when "Scroll as marquee"
  is enabled. Reads the message text from the section's _announcement blocks,
  so content stays fully editable in the Theme Editor.

  Colors are NOT hard-coded: the bar uses the theme's primary-button colors
  (filled accent background + contrasting text), which follow whatever you set
  in the Theme Editor. The separator inherits the text color.

  Accepts:
    section   - the header-announcements section object

  To revert: turn off "Scroll as marquee" in the announcement bar settings, or
  delete this file plus its render call + marquee settings in
  sections/header-announcements.liquid.
{% endcomment %}

{% liquid
  assign sep = section.settings.marquee_separator | default: 'leaf'
  assign repeat = section.settings.marquee_repeat | default: 6
  assign speed = section.settings.marquee_speed | default: 25
  assign gap = section.settings.marquee_gap | default: 40

  comment
    Messages are gathered in the section file (where section.blocks is reliably
    in scope) and passed in as a '|||'-joined string. Fall back to reading the
    blocks here if a caller renders this snippet without messages_raw.
  endcomment
  assign messages_raw = messages_raw | default: ''
  if messages_raw == blank
    for block in section.blocks
      assign txt = block.settings.text | strip_newlines | strip_html | strip
      if txt != blank
        assign messages_raw = messages_raw | append: txt | append: '|||'
      endif
    endfor
  endif
  assign messages = messages_raw | split: '|||'
%}

{% capture separator_svg %}
  {% case sep %}
    {% when 'leaf' %}
      <svg class="cust-ann__sep-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66C7.5 17 9.24 14.5 12 13c.6 7-2 9-2 9s9-3 9-13c0-2 .5-3 1-4 0 0-2.5-1-3 3Z"/>
      </svg>
    {% when 'lightning' %}
      <svg class="cust-ann__sep-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M13 2 4.5 13.5H11l-1 8.5 8.5-12H12l1-8Z"/>
      </svg>
    {% when 'star' %}
      <svg class="cust-ann__sep-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M12 2l2.2 6.6H21l-5.4 3.9 2 6.5L12 15.7 6.4 19l2-6.5L3 8.6h6.8L12 2Z"/>
      </svg>
    {% else %}
      <span class="cust-ann__sep-dot" aria-hidden="true">&bull;</span>
  {% endcase %}
{% endcapture %}

{% if messages.size > 0 %}
  <div
    class="cust-ann"
    style="--cust-ann-speed: {{ speed }}s; --cust-ann-gap: {{ gap }}px;"
  >
    <div class="cust-ann__viewport">
      <div class="cust-ann__track">
        {% for pass in (1..2) %}
          <div class="cust-ann__group" {% if pass == 2 %}aria-hidden="true"{% endif %}>
            {% for n in (1..repeat) %}
              {% for msg in messages %}
                <span class="cust-ann__item">{{ msg }}</span>
                <span class="cust-ann__sep">{{ separator_svg }}</span>
              {% endfor %}
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% style %}
    /* Bold filled accent bar — colors from the theme's primary-button scheme. */
    #shopify-section-{{ section.id }} .announcement-bar {
      background-color: var(--color-primary-button-background, rgb(var(--color-foreground-rgb)));
      padding-inline: 0;
    }

    #shopify-section-{{ section.id }} .cust-ann {
      width: 100%;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .cust-ann__viewport {
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .cust-ann__track {
      display: flex;
      width: max-content;
      animation: cust-ann-scroll-{{ section.id }} var(--cust-ann-speed) linear infinite;
    }

    #shopify-section-{{ section.id }} .cust-ann:hover .cust-ann__track {
      animation-play-state: paused;
    }

    #shopify-section-{{ section.id }} .cust-ann__group {
      display: flex;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .cust-ann__item {
      color: var(--color-primary-button-text, rgb(var(--color-background-rgb)));
      font-family: var(--font-subheading--family, inherit);
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      white-space: nowrap;
      padding-inline: calc(var(--cust-ann-gap) / 2);
    }

    #shopify-section-{{ section.id }} .cust-ann__sep {
      display: inline-flex;
      align-items: center;
      color: var(--color-primary-button-text, rgb(var(--color-background-rgb)));
      opacity: 0.85;
    }

    #shopify-section-{{ section.id }} .cust-ann__sep-icon {
      width: 1.05em;
      height: 1.05em;
    }

    #shopify-section-{{ section.id }} .cust-ann__sep-dot {
      font-size: 1rem;
      line-height: 1;
    }

    @keyframes cust-ann-scroll-{{ section.id }} {
      from { transform: translateX(0); }
      /* Two identical groups → -50% lands exactly on the seam. */
      to { transform: translateX(-50%); }
    }

    @media (prefers-reduced-motion: reduce) {
      #shopify-section-{{ section.id }} .cust-ann__track {
        animation: none;
        justify-content: center;
      }
      #shopify-section-{{ section.id }} .cust-ann__group[aria-hidden='true'] {
        display: none;
      }
      #shopify-section-{{ section.id }} .cust-ann__viewport {
        overflow-x: auto;
      }
    }
  {% endstyle %}
{% endif %}
