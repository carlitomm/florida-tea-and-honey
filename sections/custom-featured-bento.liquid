{% comment %}
  custom-featured-bento.liquid
  ----------------------------------------------------------------------------
  KICK-inspired "featured products" bento grid. On desktop: one large card on
  the left + two small cards top-right + one wide card bottom-right. On mobile:
  the cards become a swipeable scroll-snap carousel with pagination dots (same
  pattern as custom-collection-cards).

  Each card features a PRODUCT the merchant picks in the Theme Editor — nothing
  is hard-coded. The product supplies the image + "Shop Now" link; the heading,
  subheading and button label are free text (so you can write "Sets", "Kombucha"
  etc. like the reference). An optional image override per card is available.

  Colors follow the theme color schemes (cream by default, scheme-1). To revert:
  delete this file and its entry in templates/index.json.
{% endcomment %}

{% liquid
  assign card_scheme = section.settings.card_color_scheme
  assign row_h = section.settings.row_height | default: 240
  assign gap = section.settings.cards_gap | default: 16
  assign radius = section.settings.corner_radius | default: 16
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="featured-bento-{{ section.id }}"
>
  {% if section.settings.heading != blank %}
    <h2 class="bento__section-title">{{ section.settings.heading }}</h2>
  {% endif %}

  <div
    class="bento"
    style="
      --bento-row: {{ row_h }}px;
      --bento-gap: {{ gap }}px;
      --bento-radius: {{ radius }}px;
    "
  >
    {% for block in section.blocks %}
      {% liquid
        assign product = block.settings.product
        assign img = block.settings.image
        if img == blank and product != blank
          assign img = product.featured_image
        endif
        assign url = block.settings.link
        if url == blank and product != blank
          assign url = product.url
        endif
        assign title = block.settings.heading
        if title == blank and product != blank
          assign title = product.title
        endif

        assign variant = 'small'
        if forloop.index == 1
          assign variant = 'large'
        elsif forloop.index == 4
          assign variant = 'wide'
        endif
      %}
      <div
        class="bento__card bento__card--{{ variant }}"
        {{ block.shopify_attributes }}
      >
        <div class="bento__media">
          {% if img != blank %}
            {{
              img
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                class: 'bento__img',
                widths: '400, 700, 1000, 1200',
                sizes: '(min-width: 750px) 50vw, 85vw'
            }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'bento__img bento__img--placeholder' }}
          {% endif %}
        </div>
        <div class="bento__overlay" aria-hidden="true"></div>
        <div class="bento__text">
          {% if title != blank %}
            <h3 class="bento__heading">{{ title }}</h3>
          {% endif %}
          {% if block.settings.subheading != blank %}
            <p class="bento__subheading">{{ block.settings.subheading }}</p>
          {% endif %}
          {% if block.settings.button_label != blank and url != blank %}
            <a class="bento__button" href="{{ url }}">{{ block.settings.button_label }}</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    {% comment %} Mobile-only pagination dots (hidden on desktop via CSS). {% endcomment %}
    <div class="bento__dots" role="tablist" aria-label="Featured slides">
      {% for block in section.blocks %}
        <button
          type="button"
          class="bento__dot{% if forloop.first %} is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        ></button>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .bento__section-title {
    margin: 0 0 var(--gap-lg);
  }

  .bento {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: var(--bento-row) var(--bento-row);
    grid-template-areas:
      'a b c'
      'a d d';
    gap: var(--bento-gap, 16px);
  }

  .bento__card--large { grid-area: a; }
  .bento__card--small:nth-of-type(2) { grid-area: b; }
  .bento__card--small:nth-of-type(3) { grid-area: c; }
  .bento__card--wide { grid-area: d; }

  /* Full-bleed image card: the product image fills the whole card, text overlaid. */
  .bento__card {
    position: relative;
    overflow: hidden;
    border-radius: var(--bento-radius, 16px);
    isolation: isolate;
  }

  .bento__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bento__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s var(--animation-easing, ease);
  }

  .bento__card:hover .bento__img {
    transform: scale(1.04);
  }

  /* Gradient for legibility, strongest where the text sits (top). */
  .bento__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgb(0 0 0 / 0.55) 0%,
      rgb(0 0 0 / 0.25) 35%,
      rgb(0 0 0 / 0) 70%
    );
  }

  .bento__text {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: 0.5rem;
    padding: clamp(1.1rem, 2vw, 1.75rem);
  }

  .bento__heading {
    margin: 0;
    color: #fff;
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: clamp(1.25rem, 1.8vw, 1.9rem);
    line-height: 1.1;
  }

  .bento__subheading {
    margin: 0;
    max-width: 28ch;
    color: rgb(255 255 255 / 0.88);
    font-size: var(--font-size--sm, 0.9rem);
    line-height: 1.35;
  }

  .bento__button {
    display: inline-block;
    margin-top: 0.4rem;
    padding: 0.5rem 1.4rem;
    border: 1px solid transparent;
    border-radius: 999px;
    background: var(--color-primary);
    color: var(--color-primary-button-text, #fff);
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: background-color 0.18s ease, color 0.18s ease;
  }

  .bento__button:hover {
    background: var(--color-primary-hover, var(--color-primary));
  }

  /* Placeholder SVG sits on a neutral surface until a product image is set. */
  .bento__img--placeholder {
    object-fit: contain;
    background: rgb(var(--color-foreground-rgb) / 0.05);
    padding: 12%;
  }

  /* Wide card: anchor the text to the left. */
  .bento__card--wide .bento__text {
    align-items: flex-start;
    text-align: left;
  }

  /* Dots are mobile-only. */
  .bento__dots {
    display: none;
  }

  @media screen and (max-width: 749px) {
    /* Bento -> swipeable scroll-snap carousel. */
    .bento {
      display: flex;
      grid-template-areas: none;
      grid-template-columns: none;
      grid-template-rows: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scroll-padding-inline: var(--page-margin, 1rem);
      padding-block-end: 4px;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .bento::-webkit-scrollbar {
      display: none;
    }

    .bento__card,
    .bento__card--large,
    .bento__card--small,
    .bento__card--wide {
      grid-area: auto;
      flex: 0 0 82%;
      flex-direction: column;
      height: calc(var(--bento-row, 240px) * 1.7);
      scroll-snap-align: center;
    }

    .bento__card--wide .bento__text,
    .bento__card--wide .bento__media {
      flex: 0 1 auto;
      align-items: center;
      text-align: center;
    }

    .bento__card--wide .bento__text {
      text-align: center;
    }

    .bento__dots {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-block-start: 0.9rem;
    }

    .bento__dot {
      inline-size: 8px;
      block-size: 8px;
      padding: 0;
      border: 0;
      border-radius: 50%;
      background: rgb(var(--color-foreground-rgb) / 0.3);
      cursor: pointer;
      transition: background-color 0.2s ease, transform 0.2s ease;
    }

    .bento__dot.is-active {
      background: rgb(var(--color-foreground-rgb) / 0.9);
      transform: scale(1.25);
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;
    var track = section.querySelector('.bento');
    var dotsWrap = section.querySelector('.bento__dots');
    if (!track || !dotsWrap) return;
    var cards = Array.prototype.slice.call(track.querySelectorAll('.bento__card'));
    var dots = Array.prototype.slice.call(dotsWrap.querySelectorAll('.bento__dot'));
    if (cards.length < 2 || dots.length !== cards.length) return;

    function setActive(i) {
      dots.forEach(function (d, idx) {
        var on = idx === i;
        d.classList.toggle('is-active', on);
        d.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }

    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () {
        cards[i].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });
    });

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
              var idx = cards.indexOf(entry.target);
              if (idx > -1) setActive(idx);
            }
          });
        },
        { root: track, threshold: [0.6] }
      );
      cards.forEach(function (c) {
        io.observe(c);
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Featured bento",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading (optional)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "row_height",
      "label": "Row height",
      "min": 160,
      "max": 360,
      "step": 10,
      "unit": "px",
      "default": 240
    },
    {
      "type": "range",
      "id": "cards_gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section background",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Featured card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override (optional)",
          "info": "Defaults to the product's featured image."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Title",
          "info": "Defaults to the product title if left blank."
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subtitle (optional)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button link (optional)",
          "info": "Defaults to the selected product."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Featured bento",
      "category": "Products",
      "blocks": [
        { "type": "card", "settings": { "heading": "Sets", "subheading": "Handpicked combos to sample your favorites." } },
        { "type": "card", "settings": { "heading": "Honey" } },
        { "type": "card", "settings": { "heading": "Cacao" } },
        { "type": "card", "settings": { "heading": "Teas", "subheading": "Organic loose leaf, crafted by locals." } }
      ]
    }
  ]
}
{% endschema %}
