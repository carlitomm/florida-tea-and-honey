{% comment %}
  custom-collection-cards.liquid
  ----------------------------------------------------------------------------
  KICK-inspired row of clickable cards. Each card has a background image, a
  dark gradient overlay for legibility, and an editable heading, and links to
  a collection (or any URL). Fully editable from the Theme Editor:
    - Add/remove/reorder cards (blocks)
    - Per card: pick an image, edit the heading, set the link
    - Section: columns, card height, corner radius, overlay strength, color,
      padding

  Colors are NOT hard-coded as brand colors: the gradient overlay is a neutral
  black for text legibility over photos (standard for image cards), the heading
  uses the theme heading font. Everything else follows theme color schemes.
{% endcomment %}

{% liquid
  assign cols = section.settings.columns | default: 4
  assign mobile_cols = section.settings.mobile_columns | default: '1'
  assign overlay = section.settings.overlay_opacity | times: 0.01
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="collection-cards-{{ section.id }}"
>
  {% if section.settings.heading != blank %}
    <h2 class="collection-cards__section-title">{{ section.settings.heading }}</h2>
  {% endif %}

  <div
    class="collection-cards"
    style="
      --cards-columns: {{ cols }};
      --cards-mobile-columns: {{ mobile_cols }};
      --cards-radius: {{ section.settings.corner_radius }}px;
      --cards-height: {{ section.settings.card_height }}px;
      --cards-overlay: {{ overlay }};
      --cards-gap: {{ section.settings.cards_gap }}px;
    "
  >
    {% for block in section.blocks %}
      <a
        class="collection-cards__card"
        {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
        {{ block.shopify_attributes }}
      >
        <div class="collection-cards__media">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                class: 'collection-cards__img',
                widths: '300, 500, 700, 1000',
                sizes: '(min-width: 750px) 25vw, 90vw'
            }}
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'collection-cards__img collection-cards__placeholder' }}
          {% endif %}
        </div>
        <div class="collection-cards__overlay" aria-hidden="true"></div>
        <div class="collection-cards__content">
          {% if block.settings.heading != blank %}
            <h3 class="collection-cards__heading">{{ block.settings.heading }}</h3>
          {% endif %}
          {% if block.settings.subheading != blank %}
            <p class="collection-cards__subheading">{{ block.settings.subheading }}</p>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    {% comment %} Mobile-only pagination dots (hidden on desktop via CSS). {% endcomment %}
    <div class="collection-cards__dots" role="tablist" aria-label="Collection slides">
      {% for block in section.blocks %}
        <button
          type="button"
          class="collection-cards__dot{% if forloop.first %} is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
          {% if forloop.first %}aria-selected="true"{% else %}aria-selected="false"{% endif %}
        ></button>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .collection-cards__section-title {
    margin: 0 0 var(--gap-lg);
  }

  .collection-cards {
    display: grid;
    grid-template-columns: repeat(var(--cards-columns, 4), 1fr);
    gap: var(--cards-gap, 16px);
  }

  .collection-cards__card {
    position: relative;
    display: block;
    height: var(--cards-height, 360px);
    border-radius: var(--cards-radius, 16px);
    overflow: hidden;
    text-decoration: none;
    isolation: isolate;
  }

  .collection-cards__media,
  .collection-cards__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .collection-cards__img {
    object-fit: cover;
    transition: transform 0.45s var(--animation-easing, ease);
  }

  .collection-cards__card:hover .collection-cards__img {
    transform: scale(1.05);
  }

  .collection-cards__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgb(0 0 0 / var(--cards-overlay, 0.45)) 0%,
      rgb(0 0 0 / calc(var(--cards-overlay, 0.45) * 0.4)) 45%,
      rgb(0 0 0 / 0) 100%
    );
  }

  .collection-cards__content {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    text-align: left;
    gap: var(--gap-3xs, 0.25rem);
    padding: var(--padding-xl, 2rem);
  }

  .collection-cards__heading {
    margin: 0;
    color: #fff;
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: clamp(1.25rem, 1.6vw, 1.75rem);
    line-height: 1.1;
  }

  .collection-cards__subheading {
    margin: 0;
    color: rgb(255 255 255 / 0.85);
    font-size: var(--font-size--sm, 0.875rem);
  }

  /* Dots are mobile-only; hidden on desktop. */
  .collection-cards__dots {
    display: none;
  }

  @media screen and (max-width: 749px) {
    /* Turn the grid into a swipeable, snapping horizontal carousel. */
    .collection-cards {
      display: flex;
      grid-template-columns: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scroll-padding-inline: var(--page-margin, 1rem);
      padding-block-end: 4px;
      /* Hide scrollbar (Firefox / IE) — WebKit handled below. */
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .collection-cards::-webkit-scrollbar {
      display: none;
    }

    .collection-cards__card {
      flex: 0 0 82%;
      height: calc(var(--cards-height, 360px) * 0.9);
      scroll-snap-align: center;
    }

    /* Pagination dots */
    .collection-cards__dots {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-block-start: 0.9rem;
    }

    .collection-cards__dot {
      inline-size: 8px;
      block-size: 8px;
      padding: 0;
      border: 0;
      border-radius: 50%;
      background: rgb(var(--color-foreground-rgb) / 0.3);
      cursor: pointer;
      transition: background-color 0.2s ease, transform 0.2s ease;
    }

    .collection-cards__dot.is-active {
      background: rgb(var(--color-foreground-rgb) / 0.9);
      transform: scale(1.25);
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;
    var track = section.querySelector('.collection-cards');
    var dotsWrap = section.querySelector('.collection-cards__dots');
    if (!track || !dotsWrap) return;
    var cards = Array.prototype.slice.call(track.querySelectorAll('.collection-cards__card'));
    var dots = Array.prototype.slice.call(dotsWrap.querySelectorAll('.collection-cards__dot'));
    if (cards.length < 2 || dots.length !== cards.length) return;

    function setActive(i) {
      dots.forEach(function (d, idx) {
        var on = idx === i;
        d.classList.toggle('is-active', on);
        d.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }

    // Tap a dot -> snap to that card.
    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () {
        cards[i].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });
    });

    // Track the centered card while swiping and light up its dot.
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
              var idx = cards.indexOf(entry.target);
              if (idx > -1) setActive(idx);
            }
          });
        },
        { root: track, threshold: [0.6] }
      );
      cards.forEach(function (c) {
        io.observe(c);
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Collection cards",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading (optional)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 360
    },
    {
      "type": "range",
      "id": "cards_gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Collection title"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (collection, page, or URL)"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Collection cards",
      "category": "Collections",
      "blocks": [
        { "type": "card", "settings": { "heading": "Explore New Tastes" } },
        { "type": "card", "settings": { "heading": "Best Sellers" } },
        { "type": "card", "settings": { "heading": "Honey & Cacao" } },
        { "type": "card", "settings": { "heading": "Teas" } }
      ]
    }
  ]
}
{% endschema %}
